# Example inbox-queue config. Copy to inbox_queue_config.toml and set paths.
# Each tab has optional tabName and one or two paths (source, optional destination).
# Channel folders under each path must contain "Videos not transcribed" and "Videos 1 to be transcribed".

tabs = [
  { tabName = "Primary", path = "/path/to/channel/base" },
  # Two-path tab: source and destination; queue from source moves to destination.
  # { tabName = "Import", paths = [ "/source/base", "/destination/base" ] },
]
